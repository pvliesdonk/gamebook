{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/core/**",
              "components/feedback/**",
              "components/forms/**",
              "components/media/**",
              "ui_kits/print/**",
              "ui_kits/wiki/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Letter Gothic|Cronos|Cronos Caption|Jenson Display|Jenson Subhead|Jenson Text|Jenson Caption))/i]",
        "message": "Font not provided by the design system. Available: Letter Gothic, Cronos, Cronos Caption, Jenson Display, Jenson Subhead, Jenson Text, Jenson Caption."
      },
      {
        "selector": "JSXOpeningElement[name.name='BacklinkItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|taxon|href|key|ref|className|style|children)$/]",
        "message": "<BacklinkItem> doesn't accept that prop. Declared props: title, taxon, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|iconLeft|iconRight|onClick|type|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, iconLeft, iconRight, onClick, type."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|title|plate|sidebar|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: kind, title, plate, sidebar, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:specimen|fieldnote|hazard)$/]",
        "message": "<Callout> kind must be one of 'specimen' | 'fieldnote' | 'hazard'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|taxon|title|silhouette|tags|media|href|key|ref|className|style|children)$/]",
        "message": "<EntryCard> doesn't accept that prop. Declared props: number, taxon, title, silhouette, tags, media, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='EntryCard'] > JSXAttribute[name.name='media'] > Literal[value!=/^(?:if|live|tabletop|hunt)$/]",
        "message": "<EntryCard> media must be one of 'if' | 'live' | 'tabletop' | 'hunt'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|count|onClick|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: children, active, count, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|label|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IllustrationPlate'] > JSXAttribute > JSXIdentifier[name!=/^(?:figure|caption|src|alt|ratio|tone|framed|style|key|ref|className|style|children)$/]",
        "message": "<IllustrationPlate> doesn't accept that prop. Declared props: figure, caption, src, alt, ratio, tone, framed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IllustrationPlate'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:moss|slate|clay|ochre|amber)$/]",
        "message": "<IllustrationPlate> tone must be one of 'moss' | 'slate' | 'clay' | 'ochre' | 'amber'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MediaBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:media|label|solid|key|ref|className|style|children)$/]",
        "message": "<MediaBadge> doesn't accept that prop. Declared props: media, label, solid."
      },
      {
        "selector": "JSXOpeningElement[name.name='MediaBadge'] > JSXAttribute[name.name='media'] > Literal[value!=/^(?:if|live|tabletop|hunt)$/]",
        "message": "<MediaBadge> media must be one of 'if' | 'live' | 'tabletop' | 'hunt'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProvenanceMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|key|ref|className|style|children)$/]",
        "message": "<ProvenanceMark> doesn't accept that prop. Declared props: kind."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProvenanceMark'] > JSXAttribute[name.name='kind'] > Literal[value!=/^(?:corpus|researched|synthesis)$/]",
        "message": "<ProvenanceMark> kind must be one of 'corpus' | 'researched' | 'synthesis'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|defaultValue|placeholder|onChange|size|key|ref|className|style|children)$/]",
        "message": "<SearchInput> doesn't accept that prop. Declared props: value, defaultValue, placeholder, onChange, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='SearchInput'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|lg)$/]",
        "message": "<SearchInput> size must be one of 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Silhouette'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Silhouette> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|key|ref|className|style|children)$/]",
        "message": "<StatRow> doesn't accept that prop. Declared props: label, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|size|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, accent, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Tag> size must be one of 'sm' | 'md'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
